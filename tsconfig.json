{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@ubs-platform/neolith",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    "outDir": "./dist",
    "paths": {
      "@ubs-platform/neolith": ["./src/package/core"],
      "@ubs-platform/neolith/jsx-runtime": ["./src/package/core/jsx-runtime"],
      "@ubs-platform/neolith/jsx-dev-runtime": ["./src/package/core/jsx-dev-runtime"]
    }
  },
  "include": ["src"]
}
