{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "experimentalDecorators": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@ubs-platform/neolit",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    "outDir": "./dist",
    "paths": {
      "@ubs-platform/neolit/core": ["./src/package/core"],
      "@ubs-platform/neolit/injectables": ["./src/package/injectables"],
      "@ubs-platform/neolit/structural": ["./src/package/structural"],
      "@ubs-platform/neolit/jsx-runtime": ["./src/package/jsx/jsx-runtime.ts"],
      "@ubs-platform/neolit/jsx-dev-runtime": ["./src/package/jsx/jsx-dev-runtime.ts"]
    }
  },
  "include": ["src"]
}
